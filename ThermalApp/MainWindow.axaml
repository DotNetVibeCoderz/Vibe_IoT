<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ThermalApp.MainWindow"
        Width="800"
        Height="480"
        Title="ThermalApp - MLX90640 Thermal Viewer">
	<Grid RowDefinitions="Auto,*" Margin="6">
		<!-- Top Control Panel -->
		<Border Background="#222" CornerRadius="6" Padding="8" Grid.Row="0">
			<Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto" >
				<StackPanel>
					<TextBlock Text="Data Source" Foreground="White" FontSize="12"/>
					<ComboBox x:Name="DataSourceCombo" Width="120" SelectedIndex="0"/>
				</StackPanel>

				<StackPanel Grid.Column="1">
					<TextBlock Text="Min Temp (°C)" Foreground="White" FontSize="12"/>
					<NumericUpDown x:Name="MinTempUpDown" Width="120" Minimum="-40" Maximum="300" Increment="0.5"/>
				</StackPanel>

				<StackPanel Grid.Column="2">
					<TextBlock Text="Max Temp (°C)" Foreground="White" FontSize="12"/>
					<NumericUpDown x:Name="MaxTempUpDown" Width="120" Minimum="-40" Maximum="300" Increment="0.5"/>
				</StackPanel>

				<StackPanel Grid.Column="3">
					<TextBlock Text="Refresh (ms)" Foreground="White" FontSize="12"/>
					<NumericUpDown x:Name="RefreshUpDown" Width="120" Minimum="50" Maximum="2000" Increment="50"/>
				</StackPanel>

				<StackPanel Grid.Row="1">
					<Button x:Name="ToggleButton" Content="Start" Width="120" Margin="0,6,0,0"/>
				</StackPanel>

				<StackPanel Grid.Row="1" Grid.Column="1">
					<TextBlock Text="Scale Mode" Foreground="White" FontSize="12"/>
					<ComboBox x:Name="ScaleModeCombo" Width="120" SelectedIndex="0"/>
				</StackPanel>

				<StackPanel Grid.Row="1" Grid.Column="2">
					<TextBlock Text="Last Frame Avg (°C)" Foreground="White" FontSize="12"/>
					<TextBlock x:Name="AvgTempText" FontSize="14" Foreground="#90EE90"/>
				</StackPanel>

				<StackPanel Grid.Row="1" Grid.Column="3">
					<TextBlock Text="Last Frame Max (°C)" Foreground="White" FontSize="12"/>
					<TextBlock x:Name="MaxTempText" FontSize="14" Foreground="#FF8C8C"/>
				</StackPanel>
			</Grid>
		</Border>

		<!-- Thermal Grid -->
		<Border Grid.Row="1" Margin="0,8,0,0" Background="#111" CornerRadius="6" Padding="8">
			<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
				<ItemsControl x:Name="ThermalGrid"/>
			</ScrollViewer>
		</Border>
	</Grid>
</Window>
