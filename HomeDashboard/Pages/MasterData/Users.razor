@page "/users"
@using HomeDashboard.Data
@using HomeDashboard.Models
@using Microsoft.EntityFrameworkCore
@using System.Text
@using CsvHelper
@using System.Globalization
@using System.IO
@inject AppDbContext DbContext
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<PageTitle>Master Data - Users</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4" Style="color: white; text-shadow: 1px 1px 2px black;">User Management</MudText>

<MudPaper Class="glass-panel pa-4">
    <div class="d-flex justify-end mb-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mr-2" OnClick="OpenAddDialog">Add User</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ExportToCsv">Export CSV</MudButton>
    </div>

    <MudDataGrid T="User" Items="@UserList" Filterable="true" SortMode="SortMode.Multiple" Groupable="false" Bordered="true" Striped="true" QuickFilter="@QuickFilter">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Users</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="searchString" Placeholder="Search..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="ID" />
            <PropertyColumn Property="x => x.FullName" Title="Full Name" />
            <PropertyColumn Property="x => x.Email" Title="Email" />
            <PropertyColumn Property="x => x.Username" Title="Username" />
            <PropertyColumn Property="x => x.Role" Title="Role" />
            <PropertyColumn Property="x => x.CreatedAt" Title="Created At" Format="yyyy-MM-dd" />
            <TemplateColumn CellClass="d-flex justify-end">
                <CellTemplate>
                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Outlined.Edit" OnClick="@(() => OpenEditDialog(context.Item))" />
                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Outlined.Delete" Color="Color.Error" OnClick="@(() => DeleteUser(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="User" />
        </PagerContent>
    </MudDataGrid>
</MudPaper>

@if (ShowDialog)
{
    <MudOverlay Visible="true" DarkBackground="true" Absolute="false">
        <MudPaper Class="pa-4 glass-panel" Width="400px">
            <MudText Typo="Typo.h6">@(EditingUser.Id == 0 ? "Add" : "Edit") User</MudText>
            <MudTextField @bind-Value="EditingUser.FullName" Label="Full Name" />
            <MudTextField @bind-Value="EditingUser.Email" Label="Email" />
            <MudTextField @bind-Value="EditingUser.Username" Label="Username" />
            <MudTextField @bind-Value="EditingUser.Password" Label="Password" InputType="InputType.Password" />
            <MudSelect @bind-Value="EditingUser.Role" Label="Role">
                <MudSelectItem Value="@("admin")">Admin</MudSelectItem>
                <MudSelectItem Value="@("user")">User</MudSelectItem>
            </MudSelect>
            <div class="d-flex justify-end mt-4">
                <MudButton OnClick="CloseDialog" Class="mr-2">Cancel</MudButton>
                <MudButton Color="Color.Primary" OnClick="SaveUser">Save</MudButton>
            </div>
        </MudPaper>
    </MudOverlay>
}

<script>
    window.downloadFile = function(fileName, contentBase64, contentType) {
        const link = document.createElement('a');
        link.download = fileName;
        link.href = `data:${contentType};base64,${contentBase64}`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    };
</script>

@code {
    private List<User> UserList = new();
    private string searchString = string.Empty;
    
    private bool ShowDialog = false;
    private User EditingUser = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        UserList = await DbContext.Users.ToListAsync();
    }

    private Func<User, bool> QuickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (x.FullName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (x.Email.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (x.Username.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    };

    private void OpenAddDialog()
    {
        EditingUser = new User();
        ShowDialog = true;
    }

    private void OpenEditDialog(User user)
    {
        EditingUser = new User
        {
            Id = user.Id,
            FullName = user.FullName,
            Email = user.Email,
            Username = user.Username,
            Password = user.Password,
            Role = user.Role,
            CreatedAt = user.CreatedAt
        };
        ShowDialog = true;
    }

    private void CloseDialog()
    {
        ShowDialog = false;
    }

    private async Task SaveUser()
    {
        if (EditingUser.Id == 0)
        {
            DbContext.Users.Add(EditingUser);
        }
        else
        {
            var userInDb = await DbContext.Users.FindAsync(EditingUser.Id);
            if (userInDb != null)
            {
                userInDb.FullName = EditingUser.FullName;
                userInDb.Email = EditingUser.Email;
                userInDb.Username = EditingUser.Username;
                if (!string.IsNullOrEmpty(EditingUser.Password))
                {
                    userInDb.Password = EditingUser.Password;
                }
                userInDb.Role = EditingUser.Role;
                DbContext.Users.Update(userInDb);
            }
        }
        
        await DbContext.SaveChangesAsync();
        await LoadData();
        ShowDialog = false;
        Snackbar.Add("User saved successfully", Severity.Success);
    }

    private async Task DeleteUser(User user)
    {
        DbContext.Users.Remove(user);
        await DbContext.SaveChangesAsync();
        await LoadData();
        Snackbar.Add("User deleted", Severity.Error);
    }

    private async Task ExportToCsv()
    {
        using var memoryStream = new MemoryStream();
        using var writer = new StreamWriter(memoryStream);
        using var csv = new CsvWriter(writer, CultureInfo.InvariantCulture);
        
        csv.WriteRecords(UserList);
        await writer.FlushAsync();
        
        var base64 = Convert.ToBase64String(memoryStream.ToArray());
        await JSRuntime.InvokeVoidAsync("downloadFile", "users.csv", base64, "text/csv");
        Snackbar.Add("Exported successfully", Severity.Info);
    }
}