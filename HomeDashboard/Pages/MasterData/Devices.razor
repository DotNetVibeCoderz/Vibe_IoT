@page "/devices"
@using HomeDashboard.Data
@using HomeDashboard.Models
@using Microsoft.EntityFrameworkCore
@using System.IO
@using CsvHelper
@using System.Globalization
@inject AppDbContext DbContext
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<PageTitle>Master Data - Devices</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4" Style="color: white; text-shadow: 1px 1px 2px black;">Device Management</MudText>

<MudPaper Class="glass-panel pa-4">
    <div class="d-flex justify-end mb-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mr-2" OnClick="OpenAddDialog">Add Device</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ExportToCsv">Export CSV</MudButton>
    </div>

    <MudDataGrid T="Device" Items="@DeviceList" Filterable="true" SortMode="SortMode.Multiple" Bordered="true" Striped="true" QuickFilter="@QuickFilter">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Devices</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="searchString" Placeholder="Search..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="ID" />
            <PropertyColumn Property="x => x.Name" Title="Name" />
            <PropertyColumn Property="x => x.Type" Title="Type" />
            <PropertyColumn Property="x => x.Protocol" Title="Protocol" />
            <PropertyColumn Property="x => x.Room.Name" Title="Room" />
            <PropertyColumn Property="x => x.IsOn" Title="Status" />
            <TemplateColumn CellClass="d-flex justify-end">
                <CellTemplate>
                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Outlined.Edit" OnClick="@(() => OpenEditDialog(context.Item))" />
                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Outlined.Delete" Color="Color.Error" OnClick="@(() => DeleteDevice(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="Device" />
        </PagerContent>
    </MudDataGrid>
</MudPaper>

@if (ShowDialog)
{
    <MudOverlay Visible="true" DarkBackground="true" Absolute="false">
        <MudPaper Class="pa-4 glass-panel" Width="500px">
            <MudText Typo="Typo.h6">@(EditingDevice.Id == 0 ? "Add" : "Edit") Device</MudText>
            <MudTextField @bind-Value="EditingDevice.Name" Label="Device Name" />
            <MudSelect @bind-Value="EditingDevice.Type" Label="Type">
                <MudSelectItem Value="@("Light")">Light</MudSelectItem>
                <MudSelectItem Value="@("AC")">AC</MudSelectItem>
                <MudSelectItem Value="@("Camera")">Camera</MudSelectItem>
                <MudSelectItem Value="@("Sensor")">Sensor</MudSelectItem>
                <MudSelectItem Value="@("Lock")">Lock</MudSelectItem>
                <MudSelectItem Value="@("Appliance")">Appliance</MudSelectItem>
            </MudSelect>
            <MudSelect @bind-Value="EditingDevice.Protocol" Label="Protocol">
                <MudSelectItem Value="@("Wi-Fi")">Wi-Fi</MudSelectItem>
                <MudSelectItem Value="@("Zigbee")">Zigbee</MudSelectItem>
                <MudSelectItem Value="@("Z-Wave")">Z-Wave</MudSelectItem>
                <MudSelectItem Value="@("Bluetooth")">Bluetooth</MudSelectItem>
                <MudSelectItem Value="@("MQTT")">MQTT</MudSelectItem>
            </MudSelect>
            <MudSelect @bind-Value="EditingDevice.RoomId" Label="Room">
                @foreach (var room in RoomList)
                {
                    <MudSelectItem Value="@room.Id">@room.Name</MudSelectItem>
                }
            </MudSelect>
            <MudNumericField @bind-Value="EditingDevice.PowerConsumption" Label="Power Consumption (Watts)" />
            <MudSwitch T="bool" @bind-Value="EditingDevice.IsOn" Color="Color.Primary" Label="Is On?" />
            
            <div class="d-flex justify-end mt-4">
                <MudButton OnClick="CloseDialog" Class="mr-2">Cancel</MudButton>
                <MudButton Color="Color.Primary" OnClick="SaveDevice">Save</MudButton>
            </div>
        </MudPaper>
    </MudOverlay>
}

<script>
    window.downloadFile = function(fileName, contentBase64, contentType) {
        const link = document.createElement('a');
        link.download = fileName;
        link.href = `data:${contentType};base64,${contentBase64}`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    };
</script>

@code {
    private List<Device> DeviceList = new();
    private List<Room> RoomList = new();
    private string searchString = string.Empty;
    private bool ShowDialog = false;
    private Device EditingDevice = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        RoomList = await DbContext.Rooms.ToListAsync();
        DeviceList = await DbContext.Devices.Include(d => d.Room).ToListAsync();
    }

    private Func<Device, bool> QuickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        if (x.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (x.Type.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (x.Protocol.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (x.Room != null && x.Room.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        return false;
    };

    private void OpenAddDialog()
    {
        EditingDevice = new Device();
        if (RoomList.Any()) EditingDevice.RoomId = RoomList.First().Id;
        ShowDialog = true;
    }

    private void OpenEditDialog(Device device)
    {
        EditingDevice = new Device 
        { 
            Id = device.Id, 
            Name = device.Name, 
            Type = device.Type, 
            Protocol = device.Protocol,
            IsOn = device.IsOn,
            PowerConsumption = device.PowerConsumption,
            StatusValue = device.StatusValue,
            RoomId = device.RoomId
        };
        ShowDialog = true;
    }

    private void CloseDialog() => ShowDialog = false;

    private async Task SaveDevice()
    {
        if (EditingDevice.Id == 0) DbContext.Devices.Add(EditingDevice);
        else DbContext.Devices.Update(EditingDevice);
        
        await DbContext.SaveChangesAsync();
        await LoadData();
        ShowDialog = false;
        Snackbar.Add("Device saved", Severity.Success);
    }

    private async Task DeleteDevice(Device device)
    {
        DbContext.Devices.Remove(device);
        await DbContext.SaveChangesAsync();
        await LoadData();
        Snackbar.Add("Device deleted", Severity.Error);
    }

    private async Task ExportToCsv()
    {
        using var memoryStream = new MemoryStream();
        using var writer = new StreamWriter(memoryStream);
        using var csv = new CsvWriter(writer, CultureInfo.InvariantCulture);
        csv.WriteRecords(DeviceList.Select(d => new { d.Id, d.Name, d.Type, d.Protocol, Room = d.Room?.Name, d.IsOn, d.PowerConsumption }));
        await writer.FlushAsync();
        
        var base64 = Convert.ToBase64String(memoryStream.ToArray());
        await JSRuntime.InvokeVoidAsync("downloadFile", "devices.csv", base64, "text/csv");
        Snackbar.Add("Exported successfully", Severity.Info);
    }
}